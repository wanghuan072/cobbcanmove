PORT=3001
# 复制本文件为 .env 后修改；.env 已被 .gitignore 忽略，勿提交真实密码
ADMIN_PASSWORD=changeme

# 数据库（libSQL）：本地默认文件库，无需填写下面两项
# 线上持久化（推荐）：https://turso.tech 免费库 → 把 URL 与 Token 填到 Vercel / Railway
LIBSQL_URL=
LIBSQL_AUTH_TOKEN=
# 兼容 Turso CLI 导出的变量名：
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# 仅本地/无 Turso 时使用文件路径（默认 ./data/hub.sqlite）
SQLITE_PATH=./data/hub.sqlite

# 本地预览：1=新评论直接公开；0=需后台审核
AUTO_APPROVE_COMMENTS=1
